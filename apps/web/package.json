{
  "name": "@sessionfocus/web",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "echo \"No lint task configured for MVP\"",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build && node scripts/patch-opennext.mjs",
    "preview": "pnpm run cf:build && opennextjs-cloudflare preview",
    "deploy": "pnpm run cf:build && opennextjs-cloudflare deploy",
    "upload": "pnpm run cf:build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wrangler": "^4.105.0"
  }
}
